gemini_api_key=""

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=supersecretpassword
MINIO_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
MINIO_SERVER_URL=http://localhost:9000
MINIO_DEFAULT_BUCKET=rag-default
# Named buckets for future multi-bucket routing.
MINIO_BUCKET_UPLOAD=rag-upload
MINIO_BUCKET_PRESIGN=rag-upload
MINIO_BUCKET_DELETE=rag-upload
MINIO_BUCKET_ARCHIVE=rag-archive
# Optional compact format: role=bucket,role2=bucket2
MINIO_BUCKETS=upload=rag-upload,presign=rag-upload,delete=rag-upload,archive=rag-archive

# Kafka
KAFKA_EXTERNAL_PORT=9092
KAFKA_CFG_NODE_ID=0
KAFKA_CFG_PROCESS_ROLES=controller,broker
KAFKA_CFG_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_CFG_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_CFG_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_CFG_CONTROLLER_QUORUM_BOOTSTRAP_SERVERS=kafka:9093
KAFKA_BROKERS=localhost:9092

# MinIO service runtime
MINIO_GRPC_PORT=50052
MINIO_KAFKA_UPLOAD_TOPIC=minio.upload.request
MINIO_KAFKA_UPLOAD_GROUP=service-minio-upload
MINIO_KAFKA_RESULT_TOPIC=minio.upload.result
