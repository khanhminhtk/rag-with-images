GEMINI_API_KEY=""
SERVICE_HOST=127.0.0.1

# MinIO
MINIO_HOST_IP=${SERVICE_HOST}
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=supersecretpassword
MINIO_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=http://${SERVICE_HOST}:9001
MINIO_SERVER_URL=http://${SERVICE_HOST}:9000
MINIO_DEFAULT_BUCKET=rag-default
MINIO_BUCKET_UPLOAD=rag-default
MINIO_BUCKET_PRESIGN=rag-default
MINIO_BUCKET_DELETE=rag-default
MINIO_BUCKET_ARCHIVE=rag-default
MINIO_BUCKETS=default=rag-default

# Kafka
KAFKA_HOST_IP=${SERVICE_HOST}
KAFKA_EXTERNAL_PORT=9092
KAFKA_CFG_NODE_ID=0
KAFKA_CFG_PROCESS_ROLES=controller,broker
KAFKA_CFG_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_CFG_ADVERTISED_LISTENERS=PLAINTEXT://${SERVICE_HOST}:9092
KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_CFG_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_CFG_CONTROLLER_QUORUM_VOTERS=0@kafka:9093
KAFKA_BROKERS=${SERVICE_HOST}:9092

# Qdrant (Database)
QDRANT_GRPC_PORT=6334
QDRANT_HTTP_PORT=6333
QDRANT_HOST_IP=${SERVICE_HOST}


# MinIO service runtime
MINIO_SERVICE_PORT=50052
MINIO_KAFKA_UPLOAD_TOPIC=minio.upload.request
MINIO_KAFKA_UPLOAD_GROUP=service-minio-upload
MINIO_KAFKA_RESULT_TOPIC=minio.upload.result

# LLM service
LLM_SERVICE_PORT=50051
LLM_MODEL=models/gemini-3-flash-preview
LLM_TEMPERATURE=0.7
LLM_SERVICE_ID_GRPC=${SERVICE_HOST}
LLM_SERVICE_ID_MONITORING=${SERVICE_HOST}
LLM_SERVICE_METRIC_GRPC_PORT=40056


# Embedding service (was DLModel/Jina CLIP)
EMBEDDING_SERVICE_PORT=50053
EMBEDDING_SERVICE_ID_MONITORING_PORT=0.0.0.0
EMBEDDING_SERVICE_METRIC_GRPC_PORT=9103
EMBEDDING_SERVICE_LOG_PATH=logs/embedding_service.log
# The actual C++ config is in third_party/onnx_c++/config/config.yaml
# Path below is relative to cmd/embedding_service (where the service is typically run)
EMBEDDING_SERVICE_JINA_CONFIG=../../third_party/onnx_c++/config/config.yaml

EMBEDDING_SERVICE_KAFKA_BATCH_TEXT_TOPIC=embedding.embed.batch_text.request
EMBEDDING_SERVICE_KAFKA_BATCH_TEXT_GROUP=service-embedding-batch-text
EMBEDDING_SERVICE_KAFKA_BATCH_TEXT_RESULT_TOPIC=embedding.embed.batch_text.result

EMBEDDING_SERVICE_KAFKA_BATCH_IMAGE_TOPIC=embedding.embed.batch_image.request
EMBEDDING_SERVICE_KAFKA_BATCH_IMAGE_GROUP=service-embedding-batch-image
EMBEDDING_SERVICE_KAFKA_BATCH_IMAGE_RESULT_TOPIC=embedding.embed.batch_image.result

# Process File service
PROCESS_FILE_SERVICE_PORT=50055
PROCESS_FILE_SERVICE_ID_MONITORING_PORT=0.0.0.0
PROCESS_FILE_SERVICE_METRIC_GRPC_PORT=9105
PROCESS_FILE_SERVICE_LOG_PATH=logs/processfile_service.log
PROCESS_FILE_SERVICE_PATH_DOWNLOAD=data/process_file
PROCESS_FILE_SERVICE_BATCH_SIZE=20
PROCESS_FILE_SERVICE_MARKER_DEV_MODE=true
PROCESS_FILE_SERVICE_KAFKA_PROCESS_FILE_REQUEST_TOPIC=orchestrator.training_file.process_and_ingest.request
PROCESS_FILE_SERVICE_KAFKA_PROCESS_FILE_GROUP=service-process-file
PROCESS_FILE_SERVICE_KAFKA_PROCESS_FILE_RESULT_TOPIC=orchestrator.training_file.process_and_ingest.result

# RAG service
RAG_SERVICE_PORT=50054
RAG_SERVICE_LOG_PATH=logs/rag_service.log
RAG_QDRANT_HOST=${SERVICE_HOST}
RAG_QDRANT_PORT=6334
RAG_QDRANT_USE_GRPC=false
RAG_QDRANT_REQUEST_TIMEOUT_SECONDS=15
RAG_QDRANT_RETRY_ATTEMPTS=3
RAG_QDRANT_RETRY_BACKOFF_MS=300

# Orchestrator service
ORCHESTRATOR_SERVICE_PORT=8080
ORCHESTRATOR_SERVICE_LOG_PATH=logs/orchestrator_service.log
ORCHESTRATOR_SERVICE_SESSION_TTL_SECONDS=1800
ORCHESTRATOR_SERVICE_MEMORY_HISTORY_TOP_K=5
ORCHESTRATOR_RAG_RETRIEVAL_TOP_K=5
ORCHESTRATOR_VECTORDB_SHARDS=1
ORCHESTRATOR_VECTORDB_REPLICATION_FACTOR=1
ORCHESTRATOR_VECTORDB_ON_DISK_PAYLOAD=true
ORCHESTRATOR_VECTORDB_OPTIMIZERS_MEMMAP=true
ORCHESTRATOR_VECTORDB_TEXT_VECTOR_SIZE=768
ORCHESTRATOR_VECTORDB_TEXT_VECTOR_DISTANCE=cosine
ORCHESTRATOR_VECTORDB_IMAGE_VECTOR_SIZE=768
ORCHESTRATOR_VECTORDB_IMAGE_VECTOR_DISTANCE=cosine

# Monitoring (docker_compose_dev.yaml)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
APP_ENV=dev
CHATBOT_LOG_DIR=./logs

# Docker compose overrides
QDRANT_IMAGE=qdrant/qdrant:v1.17.1-unprivileged
QDRANT_CONTAINER_NAME=qdrant_database
QDRANT_RESTART=unless-stopped
QDRANT_USER=1000:1000
QDRANT_STORAGE_DIR=${HOME}/projects/mrag/data/qdrant_storage

MINIO_IMAGE=minio/minio:latest
MINIO_CONTAINER_NAME=minio
MINIO_RESTART=unless-stopped
MINIO_DATA_DIR=${HOME}/projects/mrag/data/minio

KAFKA_IMAGE=bitnamilegacy/kafka:latest
KAFKA_CONTAINER_NAME=kafka
KAFKA_RESTART=unless-stopped
KAFKA_USER=0:0
KAFKA_DATA_DIR=${HOME}/projects/mrag/data/kafka

GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_CONTAINER_NAME=monitoring_grafana
GRAFANA_RESTART=unless-stopped
GRAFANA_BIND_HOST=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_DATA_VOLUME=grafana-data
GRAFANA_DATASOURCES_FILE=./monitoring/grafana/datasources.yaml

PROMETHEUS_IMAGE=prom/prometheus:latest
PROMETHEUS_CONTAINER_NAME=monitoring_prometheus
PROMETHEUS_RESTART=unless-stopped
PROMETHEUS_USER=root
PROMETHEUS_BIND_HOST=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_CONFIG_FILE=./monitoring/prometheus/prometheus.yml
PROMETHEUS_DATA_VOLUME=prometheus-data
PROMETHEUS_EXTRA_HOST=host.docker.internal:host-gateway

LOKI_IMAGE=grafana/loki:2.9.4
LOKI_CONTAINER_NAME=monitoring_loki
LOKI_RESTART=unless-stopped
LOKI_USER=root
LOKI_BIND_HOST=127.0.0.1
LOKI_PORT=3100
LOKI_CONFIG_FILE=./monitoring/loki/loki-config.yaml
LOKI_DATA_VOLUME=loki-data
LOKI_WAL_VOLUME=loki-wal

PROMTAIL_IMAGE=grafana/promtail:2.9.4
PROMTAIL_CONTAINER_NAME=monitoring_promtail
PROMTAIL_RESTART=unless-stopped
PROMTAIL_USER=root
PROMTAIL_CONFIG_FILE=./monitoring/promtail/promtail-config.yaml
PROMTAIL_STATE_DIR=/tmp/promtail
